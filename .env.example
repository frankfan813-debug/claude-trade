# Copy this to .env and fill in your keys
# .env is gitignored — never commit actual keys

# Alpaca — get from https://app.alpaca.markets/brokerage/dashboard/overview
ALPACA_KEY=your_alpaca_api_key_id
ALPACA_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Perplexity — get from https://www.perplexity.ai/settings/api
PERPLEXITY_KEY=your_perplexity_api_key

# ClickUp — get token from https://app.clickup.com/settings/apps
# List ID: open a ClickUp list → copy the number from the URL
CLICKUP_TOKEN=your_clickup_personal_token
CLICKUP_LIST_ID=your_clickup_list_id
