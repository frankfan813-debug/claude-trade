# Copy this to .env and fill in your keys
# .env is gitignored — never commit actual keys

# Alpaca — get from https://app.alpaca.markets/brokerage/dashboard/overview
ALPACA_KEY=your_alpaca_api_key_id
ALPACA_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Gmail — use an App Password (not your real password)
# Enable at: myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
NOTIFY_EMAIL=your_gmail@gmail.com
